# ===================================================
# Environment Configuration Template
# ===================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ===================================================

# ---- Database ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myproject
DB_USERNAME=postgres
DB_PASSWORD=password

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- JWT ----
JWT_SECRET=replace_me_with_a_secure_secret
JWT_EXPIRATION_MS=86400000

# ---- Azure Storage ----
AZURE_STORAGE_CONNECTION=DefaultEndpointsProtocol=https;AccountName=replace_me

# ---- Mail (MailHog in dev) ----
MAIL_HOST=localhost
MAIL_PORT=1025

# ---- Application ----
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
