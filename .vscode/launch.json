{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Spring Boot (Dev)",
      "request": "launch",
      "mainClass": "com.example.project.ProjectApplication",
      "projectName": "project",
      "args": "--spring.profiles.active=dev",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "type": "java",
      "name": "Spring Boot (Debug)",
      "request": "attach",
      "hostName": "localhost",
      "port": 5005
    }
  ]
}
