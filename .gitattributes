# Normalize line endings across platforms
* text=auto eol=lf

# Explicitly declare text files
*.java text
*.xml text
*.yml text
*.yaml text
*.json text
*.properties text
*.sql text
*.md text
*.txt text
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
